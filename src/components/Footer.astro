---
import { Image } from "astro:assets";
import logo from "../assets/hangard-logo.png";
import { site, areaHref, serviceHref } from "../lib/site";
import { getService } from "../data/services";

const footerServiceKeys = [
  "services/extensions",
  "services/loft-conversions",
  "services/renovations",
  "services/basement-conversions",
  "installations/kitchens",
  "installations/bathrooms",
  "services/roofing",
  "installations/electrical",
];
const footerServices = footerServiceKeys.map((k) => getService(k)!).filter(Boolean);

const footerAreas = [
  ["watford", "Watford"],
  ["ealing", "Ealing"],
  ["richmond", "Richmond"],
  ["chiswick", "Chiswick"],
  ["uxbridge", "Uxbridge"],
  ["ruislip", "Ruislip"],
  ["harefield", "Harefield"],
] as const;

const year = new Date().getFullYear();
---

<footer class="bg-black text-bone pt-14 md:pt-24 pb-10 border-t border-white/10">
  <div class="max-w-[1200px] mx-auto px-5 md:px-10 grid grid-cols-2 md:grid-cols-12 gap-y-12 gap-x-6 mb-16">
    <div class="col-span-2 md:col-span-4 pr-6">
      <a href="/" class="inline-block mb-6">
        <Image src={logo} alt={`${site.name} — ${site.tagline}`} width={160} class="w-40 h-auto" />
      </a>
      <p class="font-body text-body-md text-bone/65 mb-6 max-w-xs">{site.description}</p>
      <div class="flex gap-3">
        <a href={site.social[0].href} aria-label="Instagram" class="w-10 h-10 grid place-items-center border border-white/15 text-bone/70 hover:text-ink hover:bg-brass hover:border-brass transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427C2.013 14.784 2 14.43 2 12v-.08c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zM12 6.865a5.135 5.135 0 100 10.27 5.135 5.135 0 000-10.27zm0 1.802a3.333 3.333 0 110 6.666 3.333 3.333 0 010-6.666zm5.338-3.205a1.2 1.2 0 100 2.4 1.2 1.2 0 000-2.4z"></path></svg>
        </a>
        <a href={site.social[1].href} aria-label="LinkedIn" class="w-10 h-10 grid place-items-center border border-white/15 text-bone/70 hover:text-ink hover:bg-brass hover:border-brass transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path></svg>
        </a>
      </div>
    </div>

    <div class="md:col-span-3 md:col-start-6">
      <h4 class="font-eyebrow text-eyebrow uppercase text-brass mb-6">Services</h4>
      <ul class="space-y-3">
        {footerServices.map((s) => (
          <li><a href={serviceHref(s.silo, s.slug)} class="text-body-md text-bone/65 hover:text-brass transition-colors">{s.navLabel}</a></li>
        ))}
        <li><a href="/services" class="text-body-md text-bone hover:text-brass transition-colors">All services &rarr;</a></li>
      </ul>
    </div>

    <div class="md:col-span-2">
      <h4 class="font-eyebrow text-eyebrow uppercase text-brass mb-6">Areas</h4>
      <ul class="space-y-3">
        {footerAreas.map(([slug, label]) => (
          <li><a href={areaHref(slug)} class="text-body-md text-bone/65 hover:text-brass transition-colors">{label}</a></li>
        ))}
        <li><a href="/service-areas" class="text-body-md text-bone hover:text-brass transition-colors">All areas &rarr;</a></li>
      </ul>
    </div>

    <div class="col-span-2 md:col-span-2">
      <h4 class="font-eyebrow text-eyebrow uppercase text-brass mb-6">Contact</h4>
      <address class="not-italic space-y-3 text-body-md text-bone/65">
        <p>{site.addressLines[0]}<br />{site.addressLines[1]}<br />{site.addressLines[2]}</p>
        <p><a href={`tel:${site.phoneHref}`} class="hover:text-brass transition-colors">{site.phoneDisplay}</a></p>
        <p><a href={`mailto:${site.email}`} class="hover:text-brass transition-colors break-words">{site.email}</a></p>
        <p class="text-bone/60 text-caption">{site.hours}</p>
      </address>
    </div>
  </div>

  <div class="max-w-[1200px] mx-auto px-5 md:px-10 pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
    <p class="font-body text-caption text-bone/60">© {year} {site.name}. All rights reserved.</p>
    <div class="flex flex-wrap gap-x-6 gap-y-2">
      <a href="/blog" class="text-caption text-bone/60 hover:text-brass transition-colors">Journal</a>
      <a href="/privacy-policy" class="text-caption text-bone/60 hover:text-brass transition-colors">Privacy Policy</a>
      <a href="/terms" class="text-caption text-bone/60 hover:text-brass transition-colors">Terms</a>
      <a href="/cookies" class="text-caption text-bone/60 hover:text-brass transition-colors">Cookies</a>
    </div>
  </div>

  <div class="max-w-[1200px] mx-auto px-5 md:px-10 mt-6 text-center">
    <p class="font-caption text-caption text-bone/55">This site is powered by <a href="https://ranklocalagency.co" target="_blank" rel="noopener" class="text-brass hover:text-bone transition-colors">Ranklocalagency</a></p>
  </div>
</footer>
