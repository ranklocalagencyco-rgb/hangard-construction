---
import { Image } from "astro:assets";
import { projectImage } from "../lib/images";
import Icon from "./Icon.astro";

interface Props {
  href: string;
  title: string;
  blurb: string;
  image: string;
  alt: string;
}
const { href, title, blurb, image, alt } = Astro.props;
---
<a
  href={href}
  class="group flex flex-col bg-surface border border-stone hover:shadow-[0_12px_30px_rgba(22,29,36,.10)] hover:-translate-y-1 transition-all duration-300"
>
  <div class="aspect-[4/3] overflow-hidden border-b border-stone">
    <Image src={projectImage(image)} alt={alt} width={760} quality={68} class="w-full h-full object-cover" loading="lazy" />
  </div>
  <div class="p-7 flex flex-col flex-1">
    <h3 class="font-heading text-headline-sm font-semibold text-ink mb-3">{title}</h3>
    <p class="font-body text-body-md text-slate mb-6 flex-1">{blurb}</p>
    <span class="inline-flex items-center text-label uppercase text-brass-deep font-label"
      >Explore<Icon name="arrow_forward" class="text-lg ml-1 group-hover:translate-x-1 transition-transform" /></span
    >
  </div>
</a>
