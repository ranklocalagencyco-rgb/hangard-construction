---
import { Image } from "astro:assets";
import { projectImage } from "../lib/images";
import { silos } from "../lib/site";
import { servicesInSilo } from "../data/services";
import type { Silo } from "../lib/types";
import Container from "./Container.astro";
import Eyebrow from "./Eyebrow.astro";
import ServiceGrid from "./ServiceGrid.astro";
import CTASection from "./CTASection.astro";

interface Props {
  silo: Silo;
}
const { silo } = Astro.props;

const meta: Record<Silo, { h1: string; lead: string; hero: string }> = {
  services: {
    h1: "Construction & renovation services",
    lead: "Five structural services — extensions, renovations, basement and loft conversions and roofing — delivered by one accountable team across West London and the Home Counties.",
    hero: "p18.png",
  },
  installations: {
    h1: "Installations",
    lead: "Kitchens, bathrooms, electrical work and plumbing & heating — designed, supplied and installed to a precise, lasting standard by one team.",
    hero: "kitchen-orangery-island.png",
  },
  maintenance: {
    h1: "Property maintenance & outdoor",
    lead: "Property maintenance, driveways, patios and landscaping — the work that keeps your home and grounds right, all year round.",
    hero: "landscaping-garden-dusk-lighting.png",
  },
};
const m = meta[silo];
const list = servicesInSilo(silo);
const ctaHeading =
  silo === "services"
    ? "Not sure which service you need?"
    : silo === "installations"
      ? "Planning a kitchen, bathroom, rewire or new boiler?"
      : "Need maintenance or outdoor work?";
---
<header class="relative pt-20 bg-black text-bone overflow-hidden">
  <div class="absolute inset-0 z-0 opacity-60">
    <Image src={projectImage(m.hero)} alt={`${silos[silo].label} — recent project`} width={1600} quality={60} class="w-full h-full object-cover" loading="eager" fetchpriority="high" />
  </div>
  <div class="absolute inset-0 z-10 pointer-events-none" style="background:linear-gradient(to top, rgba(22,29,36,.92), rgba(22,29,36,.55))"></div>
  <div class="relative z-20">
    <Container>
      <nav class="py-5 text-caption uppercase tracking-[0.06em] text-bone/50">
        <a href="/" class="hover:text-brass">Home</a> <span class="mx-2">/</span>
        <span class="text-bone/80">{silos[silo].label}</span>
      </nav>
      <div class="max-w-3xl pt-8 pb-20 md:pb-28">
        <Eyebrow dark class="mb-5">{silos[silo].eyebrow}</Eyebrow>
        <h1 class="font-heading text-headline-xl-mobile md:text-headline-xl font-semibold mb-6" style="text-wrap:balance">{m.h1}</h1>
        <p class="font-body text-body-lg text-bone/80 max-w-xl">{m.lead}</p>
      </div>
    </Container>
  </div>
</header>

<section class="py-14 md:py-24">
  <Container>
    <h2 class="sr-only">{silos[silo].label}</h2>
    <ServiceGrid services={list} />
  </Container>
</section>

<CTASection heading={ctaHeading} body="Describe your project and we'll point you to the right team and arrange a survey." />
