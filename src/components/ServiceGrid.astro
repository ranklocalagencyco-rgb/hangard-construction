---
import ServiceCard from "./ServiceCard.astro";
import { serviceHref } from "../lib/site";
import type { Service } from "../lib/types";

interface Props {
  services: Service[];
  class?: string;
}
const {
  services,
  class: className = "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6",
} = Astro.props;
---
<div class:list={[className]}>
  {
    services.map((s) => (
      <ServiceCard
        href={serviceHref(s.silo, s.slug)}
        title={s.navLabel}
        blurb={s.cardBlurb}
        image={s.cardImage}
        alt={`${s.navLabel} project`}
      />
    ))
  }
</div>
