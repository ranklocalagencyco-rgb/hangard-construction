---
import Container from "./Container.astro";
import Button from "./Button.astro";

interface Props {
  eyebrow?: string;
  heading: string;
  body: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}
const {
  eyebrow = "Start the conversation",
  heading,
  body,
  primaryHref = "/contact",
  primaryLabel = "Request a quote",
  secondaryHref = "/services",
  secondaryLabel = "View our services",
} = Astro.props;
---
<section class="bg-black text-bone">
  <Container class="py-14 md:py-24 text-center">
    <span class="font-eyebrow text-eyebrow uppercase text-brass block mb-5">{eyebrow}</span>
    <h2 class="font-heading text-headline-lg-mobile md:text-headline-lg font-semibold mb-6 max-w-2xl mx-auto">{heading}</h2>
    <p class="font-body text-body-lg text-bone/75 mb-10 max-w-xl mx-auto">{body}</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href={primaryHref} variant="brass">{primaryLabel}</Button>
      <Button href={secondaryHref} variant="outline-bone">{secondaryLabel}</Button>
    </div>
  </Container>
</section>
