---
import "@fontsource-variable/hanken-grotesk";
// TypeScript may complain about missing type declarations for this side-effect font import.
// @ts-ignore: Missing type declarations for '@fontsource-variable/inter'
import "@fontsource-variable/inter";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../lib/site";

interface Props {
  title: string;
  description: string;
  jsonLd?: object[];
  /** social share image path (under site root); defaults to the branded OG card */
  ogImage?: string;
  /** shorter description for social cards (≤125 chars); falls back to description */
  ogDescription?: string;
}
const { title, description, jsonLd, ogImage = "/og/og-default.jpg", ogDescription } = Astro.props;
const ogDesc = ogDescription ?? description;
const canonical = new URL(Astro.url.pathname, site.url).href;
const ogImageUrl = new URL(ogImage, site.url).href;
const ogImageAlt = `${site.name} — premium builders in West London`;
const graph = jsonLd ? JSON.stringify({ "@context": "https://schema.org", "@graph": jsonLd }) : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/logo/hg-mark-v2.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={ogDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={ogDesc} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- Material Symbols (icon font only; text fonts are self-hosted) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap"
      rel="stylesheet"
    />
    {graph && <script type="application/ld+json" is:inline set:html={graph} />}
    <slot name="head" />
  </head>
  <body class="bg-bone text-ink font-body antialiased selection:bg-brass/20 selection:text-ink">
    <Header />
    <slot />
    <Footer />

    <script>
      // Sticky nav: solidify on scroll
      const nav = document.getElementById("main-nav");
      function onScroll() {
        if (!nav) return;
        if (window.scrollY > 20) {
          nav.classList.add("shadow-[0_4px_12px_rgba(22,29,36,.08)]", "bg-black");
          nav.classList.remove("bg-black/90");
        } else {
          nav.classList.remove("shadow-[0_4px_12px_rgba(22,29,36,.08)]", "bg-black");
          nav.classList.add("bg-black/90");
        }
      }
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();

      // Mobile menu
      const mb = document.getElementById("menu-btn");
      const mm = document.getElementById("mobile-menu");
      const mc = document.getElementById("menu-close");
      function openM() {
        mm?.classList.remove("hidden");
        mm?.classList.add("flex");
        document.body.style.overflow = "hidden";
        mb?.setAttribute("aria-expanded", "true");
      }
      function closeM() {
        mm?.classList.add("hidden");
        mm?.classList.remove("flex");
        document.body.style.overflow = "";
        mb?.setAttribute("aria-expanded", "false");
      }
      if (mb && mm && mc) {
        mb.addEventListener("click", openM);
        mc.addEventListener("click", closeM);
        mm.querySelectorAll("a").forEach((a) => a.addEventListener("click", closeM));
      }

      // FAQ accordions
      document.querySelectorAll("[data-acc]").forEach((btn) => {
        btn.addEventListener("click", () => btn.closest(".acc")?.classList.toggle("open"));
      });
    </script>
  </body>
</html>
